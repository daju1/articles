    "                           * E_y_r(x) * exp(-I*omega_t) \n",
    "                           * conjugate(mu_r_zz_c * H_z_r(x) * exp(-I*omega_t)))\n",
    "    \n",
    "    f_P_dynamic_conj_l += 1/2*(-I*omega/c * (epsilon_l_yy_c - 1)/(4*pi) \n",
    "                           * E_y_l(x) * exp(-I*omega_t) \n",
    "                           * conjugate(mu_l_zz_c * H_z_l(x) * exp(-I*omega_t)))\n",
