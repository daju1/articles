  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "сшивая решения уравнений Максвелла на границах сред, учитывая известные граничные условия"
   ]
  },
  {
   "cell_type": "raw",
   "metadata": {},
   "source": [
    "# ======================================================\n",
    "# 3. ГРАНИЧНЫЕ УСЛОВИЯ (4 уравнения)\n",
    "# ======================================================\n",
    "# BC1, BC2 — непрерывность на левой границе x = -A\n",
    "# BC3, BC4 — условие на правой границе x = +A (зависит от типа резонатора)\n",
    "\n",
    "# граничные условия на границе вакуума внутри резонатора и проводящего металла с потерями\n",
    "# тангенциальная компонента электрического поля\n",
    "# eqEz_l = E_left_conductor_sol_z(-a) == E_inner_vacuum_sol_z(-a)\n",
    "# eq_Ey_l = E_left_conductor_sub_y(-a) == E_inner_vacuum_sub_y(-a)\n",
    "# eqEz_r = E_right_conductor_sol_z(a) == E_inner_vacuum_sol_z(a)\n",
    "# eq_Ey_r = E_right_conductor_sub_y(a) == E_inner_vacuum_sub_y(a)\n",
    "# тангенциальная компонента напряженности магнитного поля\n",
    "# eqHz_l  = (H_left_conductor_sol_z(-a) == H_inner_vacuum_sol_z(-a))\n",
    "# eq_Hy_l = (H_left_conductor_sub_y(-a) == H_inner_vacuum_sub_y(-a))\n",
    "# eqHz_r  = (H_right_conductor_sol_z(a) == H_inner_vacuum_sol_z(a))\n",
    "# eq_Hy_r = (H_right_conductor_sub_y(a) == H_inner_vacuum_sub_y(a))\n",
    "# --- Левая граница (x = -A): всегда «закорочена» (металл / PEC)\n",
    "if is_TM:\n",
    "    bc1 = eqEz_l  # Ez_v.subs(x=-A) == Ez_l.subs(x=-A)    # непрерывность E_z\n",
    "    bc2 = eq_Hy_l # Hy_v.subs(x=-A) == Hy_l.subs(x=-A)    # непрерывность H_y\n",
    "elif is_TE:\n",
    "    bc1 = eqHz_l  # Hz_v.subs(x=-A) == Hz_l.subs(x=-A)    # непрерывность H_z\n",
    "    bc2 = eq_Ey_l # Ey_v.subs(x=-A) == Ey_l.subs(x=-A)    # непрерывность E_y\n",
    "\n",
    "# --- Правая граница (x = +A): зависит от типа резонатора\n",
    "if resonator_type == \"quarter\":\n",
    "    # Разомкнутый конец: ∂_z (продольное поле) = 0\n",
    "    # → H_y = 0 при TM (∂_z E_z ∝ H_y), E_y = 0 при TE (∂_z H_z ∝ E_y)\n",
    "    if is_TM:\n",
    "        bc3 = Ez_v.subs(x=A)  == Ez_r.subs(x=A)   # непрерывность E_z\n",
    "        bc4 = Hy_v.subs(x=A)  == 0                # H_y = 0 (разомкнут)\n",
    "    elif is_TE:\n",
    "        bc3 = Hz_v.subs(x=A)  == Hz_r.subs(x=A)   # непрерывность H_z\n",
    "        bc4 = Ey_v.subs(x=A)  == 0                # E_y = 0 (разомкнут)\n",
    "\n",
    "elif resonator_type == \"half\":\n",
    "    # Закорочен на обоих концах: продольное поле = 0\n",
    "    if is_TM:\n",
    "        bc3 = Ez_v.subs(x=A)  == Ez_r.subs(x=A)   # непрерывность\n",
    "        bc4 = Ez_v.subs(x=A)  == 0                # E_z = 0 (короткое)\n",
    "    elif is_TE:\n",
    "        bc3 = Hz_v.subs(x=A)  == Hz_r.subs(x=A)   # непрерывность\n",
