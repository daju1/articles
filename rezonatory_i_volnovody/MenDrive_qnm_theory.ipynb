    "# ============================================================================\n",
    "\n",
    "# Сила Лоренца на элемент объёма: f = j × B\n",
    "# В вашей геометрии (TM-волна, поля не зависят от y, волна вдоль z):\n",
    "# Основная компонента силы будет вдоль x\n",
    "\n",
    "# Магнитная индукция B = μ₀*H (в CGS: μ₀ = 1)\n",
    "B_vacuum_x(x, t) = H_vacuum_x(x, t)\n",
    "B_vacuum_y(x, t) = H_vacuum_y(x, t)\n",
    "B_vacuum_z(x, t) = H_vacuum_z(x, t)\n",
    "\n",
    "# Векторное произведение j × B\n",
    "# f = j × B = (j_y*B_z - j_z*B_y, j_z*B_x - j_x*B_z, j_x*B_y - j_y*B_x)\n",
    "\n",
    "f_vacuum_x(x, t) = (1/c) * (j_D_y(x, t) * B_vacuum_z(x, t) - j_D_z(x, t) * B_vacuum_y(x, t))\n",
    "f_vacuum_y(x, t) = (1/c) * (j_D_z(x, t) * B_vacuum_x(x, t) - j_D_x(x, t) * B_vacuum_z(x, t))\n",
    "f_vacuum_z(x, t) = (1/c) * (j_D_x(x, t) * B_vacuum_y(x, t) - j_D_y(x, t) * B_vacuum_x(x, t))\n",
