    "# ЧАСТЬ 1: СИЛА НА ВАКУУМ МЕЖДУ СТЕНКАМИ (из предыдущего расчёта)\n",
    "# ============================================================================\n",
    "\n",
    "print(\"\\n\" + \"-\"*80)\n",
    "print(\"1. ВАКУУМ МЕЖДУ СТЕНКАМИ (-a < x < a)\")\n",
    "print(\"-\"*80)\n",
    "\n",
    "# Ток смещения в вакууме\n",
    "j_D_z_vacuum = (1/(4*pi)) * (-I*omega) * Ez_vacuum_d(x)\n",
    "\n",
    "# Сила: j_D × B\n",
    "# Для TM-волны: f_x = j_D_z × H_y\n",
    "f_vacuum_middle_x = j_D_z_vacuum * Hy_vacuum_d(x=x)\n",
    "\n",
    "# Усреднение по периоду: ⟨A·B*⟩ = (1/2)Re[A·conj(B)]\n",
    "# Но нужно быть осторожным с фазами!\n",
    "# Для exp(-iωt): ⟨f⟩ = (1/2)Re[f_амплитуда]\n",
    "\n",
    "# Упрощённый подход: численное интегрирование с подстановкой значений\n",
    "f_vacuum_middle_x_numerical = f_vacuum_middle_x.subs(digit_values)\n",
    "\n",
    "# Для комплексных полей среднее по периоду:\n",
    "# Если E = E₀·exp(-iωt) и H = H₀·exp(-iωt), то\n",
    "# j_D = -iω·ε₀·E₀·exp(-iωt)\n",
    "# ⟨j_D × H⟩ = (1/2)Re[-iω·ε₀·E₀·H₀*]\n",
    "\n",
    "# Извлекаем амплитуды (без exp(-iωt)):\n",
    "if is_TM:\n",
    "    E_amp = Ez_vacuum_d(x=x)\n",
    "    H_amp = Hy_vacuum_d(x=x)\n",
    "if is_TE:\n",
    "    E_amp = Ey_vacuum_d(x=x)\n",
    "    H_amp = Hz_vacuum_d(x=x)\n",
    "\n",
    "# Ток смещения (амплитуда): j_D = -iω·ε₀·E\n",
    "j_D_amp = (1/(4*pi)) * (-I*omega) * E_amp\n",
    "\n",
    "# Средняя сила: ⟨f⟩ = (1/2)Re[j_D·H*]\n",
    "f_avg_middle = (1/2) * (1/c) * real_part(j_D_amp * conjugate(H_amp))\n",
    "\n",
    "# Подставляем численные значения\n",
    "f_avg_middle_numerical = f_avg_middle.subs(digit_values)\n",
    "\n",
    "# Интегрируем по объёму вакуума между стенками\n",
    "try:\n",
    "    F_vacuum_middle_x = integrate(f_avg_middle_numerical, x, -float(A), float(A)).n()\n",
    "    print(f\"\\nСила на вакуум между стенками: {F_vacuum_middle_x:.6e} дин\")\n",
    "except Exception as e:\n",
    "    print(f\"\\nОшибка интегрирования: {e}\")\n",
    "    print(\"Пробуем численное интегрирование...\")\n",
    "    # Численное интегрирование точками\n",
    "    x_points = [float(-A + i*(2*A)/100) for i in range(101)]\n",
    "    f_points = [complex(f_avg_middle_numerical(x=x_val)).real for x_val in x_points]\n",
    "    F_vacuum_middle_x = sum(f_points) * (2*A/100)\n",
    "    print(f\"Сила на вакуум между стенками (численно): {F_vacuum_middle_x:.6e} дин\")\n"
