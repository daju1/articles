    "print(\"=\"*80)\n",
    "print(\"РАСЧЁТ ИМПУЛЬСА СКРЫТОГО ПОЛЯ (без излучения)\")\n",
    "print(\"⟨P_x⟩ = (1/(8πc)) ∫ Re(E_z ⋅ H_y^*) dV\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 1. Объёмная плотность импульса (усреднённая по периоду)\n",
    "# ------------------------------------------------------------\n",
    "def gfh_x_vacuum(x):\n",
    "    \"\"\"Плотность импульса в вакууме (-A ≤ x ≤ A)\"\"\"\n",
    "    if is_TM:\n",
    "        Ez = Ez_vacuum_d(x=x)\n",
    "        Dz = Dz_vacuum_d(x=x)\n",
    "        Hy = Hy_vacuum_d(x=x)\n",
    "        By = By_vacuum_d(x=x)\n",
    "        gx_v = - (1/(8*pi*c)) * real_part(             Ez * conjugate(Hy))\n",
    "        fx_v = - (1/(8*pi*c)) * real_part((-I*omega) * Ez * conjugate(By))\n",
    "        hx_v = + (1/(8*pi*c)) * real_part((-I*omega) * Hy * conjugate(Dz))\n",
    "    if is_TE:\n",
    "        Ey = Ey_vacuum_d(x=x)\n",
    "        Dy = Dy_vacuum_d(x=x)\n",
    "        Hz = Hz_vacuum_d(x=x)\n",
    "        Bz = Bz_vacuum_d(x=x)\n",
    "        gx_v = + (1/(8*pi*c)) * real_part(             Ey * conjugate(Hz))\n",
    "        fx_v = + (1/(8*pi*c)) * real_part((-I*omega) * Ey * conjugate(Bz))\n",
    "        hx_v = - (1/(8*pi*c)) * real_part((-I*omega) * Hz * conjugate(Dy))\n",
    "    return gx_v, fx_v, hx_v\n",
    "        \n",
    "\n",
    "def gfh_x_left(x):\n",
    "    \"\"\"Плотность импульса в левом проводнике (x ≤ -A)\"\"\"\n",
    "    if is_TM:\n",
    "        Ez = Ez_left_conductor_d(x=x)\n",
    "        Dz = Dz_left_conductor_d(x=x)\n",
    "        Hy = Hy_left_conductor_d(x=x)\n",
    "        By = By_left_conductor_d(x=x)\n",
    "        gx_l = - (1/(8*pi*c)) * real_part(             Ez * conjugate(Hy))\n",
    "        fx_l = - (1/(8*pi*c)) * real_part((-I*omega) * Ez * conjugate(By))\n",
    "        hx_l = + (1/(8*pi*c)) * real_part((-I*omega) * Hy * conjugate(Dy))\n",
    "    if is_TE:\n",
    "        Ey = Ey_left_conductor_d(x=x)\n",
    "        Dy = Dy_left_conductor_d(x=x)\n",
    "        Hz = Hz_left_conductor_d(x=x)\n",
    "        Bz = Bz_left_conductor_d(x=x)\n",
    "        gx_l = + (1/(8*pi*c)) * real_part(             Ey * conjugate(Hz))\n",
    "        fx_l = + (1/(8*pi*c)) * real_part((-I*omega) * Ey * conjugate(Bz))\n",
    "        hx_l = - (1/(8*pi*c)) * real_part((-I*omega) * Hz * conjugate(Dy))\n",
    "    return gx_l, fx_l, hx_l\n",
    "\n",
    "def gfh_x_right(x):\n",
    "    \"\"\"Плотность импульса в правом проводнике (x ≥ A)\"\"\"\n",
    "    if is_TM:\n",
    "        Ez = Ez_right_conductor_d(x=x)\n",
    "        Dz = Dz_right_conductor_d(x=x)\n",
    "        Hy = Hy_right_conductor_d(x=x)\n",
    "        By = By_right_conductor_d(x=x)\n",
    "        gx_r = - (1/(8*pi*c)) * real_part(             Ez * conjugate(Hy))\n",
    "        fx_r = - (1/(8*pi*c)) * real_part((-I*omega) * Ez * conjugate(By))\n",
    "        hx_r = + (1/(8*pi*c)) * real_part((-I*omega) * Hy * conjugate(Dz))\n",
    "    if is_TE:\n",
    "        Ey = Ey_right_conductor_d(x=x)\n",
    "        Dy = Dy_right_conductor_d(x=x)\n",
    "        Hz = Hz_right_conductor_d(x=x)\n",
    "        Bz = Bz_right_conductor_d(x=x)\n",
    "        gx_r = + (1/(8*pi*c)) * real_part(             Ey * conjugate(Hz))\n",
    "        fx_r = + (1/(8*pi*c)) * real_part((-I*omega) * Ey * conjugate(Bz))\n",
    "        hx_r = - (1/(8*pi*c)) * real_part((-I*omega) * Hz * conjugate(Dy))\n",
    "    return gx_r, fx_r, hx_r\n",
    "\n",
    "# ------------------------------------------------------------\n",
    "# 2. Численное интегрирование по x (на 1 см² поперечного сечения)\n",
    "# ------------------------------------------------------------\n",
    "import numpy as np\n",
    "\n",
    "def integrate_gfhx(func, index, x_min, x_max, n_points=500):\n",
    "    xs = np.linspace(float(x_min), float(x_max), n_points)\n",
    "    vals = [complex(func(x=x_val)[ind].subs(digit_values).subs(k_z_sol)).real for x_val in xs]\n",
    "    return np.trapz(vals, xs)  # интеграл по x, умножим на S = 1 см² позже\n",
    "\n",
    "# Области:\n",
    "x_left_min  = -A - h_conductor_l\n",
    "x_left_max  = -A\n",
    "x_mid_min   = -A\n",
    "x_mid_max   = A\n",
    "x_right_min = A\n",
    "x_right_max = A + h_conductor_r\n",
    "\n",
    "names = [\"Импульс поля\",\n",
    "         \"опора на электрический ток смещения\",\n",
    "         \"опора на магнитный ток смещения\",\n",
    "        ]\n",
    "\n",
    "for ind in [0, 1, 2]:\n",
    "    # Интегрируем:\n",
    "    P_left_num  = integrate_gfhx(gfh_x_left,   ind, x_left_min,  x_left_max)\n",
    "    P_mid_num   = integrate_gfhx(gfh_x_vacuum, ind, x_mid_min,   x_mid_max)\n",
    "    P_right_num = integrate_gfhx(gfh_x_right,  ind, x_right_min, x_right_max)\n",
    "\n",
    "    P_total_num = P_left_num + P_mid_num + P_right_num\n",
    "\n",
    "    print(f\"{names[ind]} в левой стенке (x < -A):    {P_left_num:.6e}   г·см/с\")\n",
    "    print(f\"{names[ind]} между стенками (-A < x < A): {P_mid_num:.6e}   г·см/с\")\n",
    "    print(f\"{names[ind]} в правой стенке (x > A):   {P_right_num:.6e}   г·см/с\")\n",
    "    print(\"-\"*80)\n",
    "    print(f\"СУММАРНЫЙ {names[ind]}:            {P_total_num:.6e}   г·см/с\")\n",
    "    print(\"\\n\")\n",
    "\n",
    "    # ------------------------------------------------------------\n",
    "    # 4. (Опционально) Построить распределение g_x(x)\n",
    "    # ------------------------------------------------------------\n",
    "    if True:  # измените на True, чтобы построить график\n",
    "        import matplotlib.pyplot as plt\n",
    "        xs_plot = np.linspace(x_left_min, x_right_max, 1000)\n",
    "        gx_vals = []\n",
    "        for xv in xs_plot:\n",
    "            if xv < -A:\n",
    "                gx = gfh_x_left(x=xv)[ind]\n",
    "            elif xv > A:\n",
    "                gx = gfh_x_right(x=xv)[ind]\n",
    "            else:\n",
    "                gx = gfh_x_vacuum(x=xv)[ind]\n",
    "\n",
    "            gx_vals.append(complex(gx.subs(digit_values).subs(k_z_sol)).real)\n",
    "\n",
    "        plt.figure(figsize=(10,4))\n",
    "        plt.plot(xs_plot, gx_vals, 'b-', linewidth=1.5)\n",
    "        plt.axvline(-A, color='k', linestyle='--', label='x = -A')\n",
    "        plt.axvline(A,  color='k', linestyle='--', label='x = +A')\n",
    "        plt.xlabel('x (см)')\n",
    "        plt.ylabel(r'$\\langle g_x \\rangle$ (г·см⁻²/с)')\n",
    "        plt.title(f\"Плотность {names[ind]} вдоль x\")\n",
    "        plt.grid(True)\n",
    "        plt.legend()\n",
    "        plt.show()\n",
    "# ------------------------------------------------------------\n",
    "# 3. Сравнение с пондеромоторной силой (проверка баланса)\n",
    "# ------------------------------------------------------------\n",
    "# Сила на устройство (уже вычислена вами, например):\n",
    "F_device = f_dyne_full  # дин = г·см/с²\n",
    "\n",
    "print(f\"\\nСила на устройство (F_device): {F_device} дин\")\n",
    "print(f\"Оценка d⟨P_x⟩/dt ~ F_device · τ (τ=1 с): {F_device} г·см/с\")\n",
    "\n",
    "if abs(P_total_num) > 1e-20:\n",
    "    print(\"\\n✅ Импульс поля НЕНУЛЕВОЙ — есть 'скрытый' импульс в стоячей волне.\")\n",
    "    if abs(P_total_num + 0) < 1e-15:\n",
    "        print(\"   Он локализован в скин-слоях (сравните P_left, P_right).\")\n",
    "else:\n",
    "    print(\"\\n⚠️ Импульс поля ≈ 0 — возможна симметрия или недостаточная точность.\")\n"
   ]
