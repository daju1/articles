    "f_vacuum_x_re(x, t) = (1/c) * (j_D_y(x, t).real() * B_vacuum_z(x, t).real() - j_D_z(x, t).real() * B_vacuum_y(x, t).real())\n",
    "f_vacuum_y_re(x, t) = (1/c) * (j_D_z(x, t).real() * B_vacuum_x(x, t).real() - j_D_x(x, t).real() * B_vacuum_z(x, t).real())\n",
    "f_vacuum_z_re(x, t) = (1/c) * (j_D_x(x, t).real() * B_vacuum_y(x, t).real() - j_D_y(x, t).real() * B_vacuum_x(x, t).real())\n",
